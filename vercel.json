{
  "version": 2,
  "builds": [
    {
      "src": "server/app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/views/**",
          "css/**",
          "js/**",
          "sw.js",
          "icons/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server/app.js" }
  ]
}
