<%- include('../layouts/head', { title: 'Login' }) %>

<div class="login-page">
  <div class="login-bg">
    <div class="login-bg__mesh"></div>
    <div class="login-bg__grid"></div>
    <div class="login-bg__orb login-bg__orb--1"></div>
    <div class="login-bg__orb login-bg__orb--2"></div>
    <div class="login-bg__orb login-bg__orb--3"></div>
  </div>

  <div class="login-hero">
    <div class="login-hero__content">
      <div class="login-hero__brand stagger-item" style="--i:0">
        <div class="login-hero__brand-icon"><i class='bx bx-plus-medical'></i></div>
        <h1>Med<span>Control</span></h1>
        <p class="login-hero__tagline">Gestão de Medicamentos</p>
      </div>

      <p class="login-hero__description stagger-item" style="--i:1">
        Plataforma inteligente para gerenciamento de prescrições médicas
        e acompanhamento de medicamentos.
      </p>

      <div class="login-hero__metrics stagger-item" style="--i:2">
        <div class="login-hero__metric">
          <span class="login-hero__metric-value">+500</span>
          <span class="login-hero__metric-label">Médicos</span>
        </div>
        <div class="login-hero__metric">
          <span class="login-hero__metric-value">+2k</span>
          <span class="login-hero__metric-label">Pacientes</span>
        </div>
        <div class="login-hero__metric">
          <span class="login-hero__metric-value">+10k</span>
          <span class="login-hero__metric-label">Prescrições</span>
        </div>
      </div>

      <div class="login-hero__features stagger-item" style="--i:3">
        <div class="login-hero__feature">
          <div class="login-hero__feature-icon"><i class='bx bx-check'></i></div>
          <span>Prescrições digitais seguras</span>
        </div>
        <div class="login-hero__feature">
          <div class="login-hero__feature-icon"><i class='bx bx-check'></i></div>
          <span>Lembretes automáticos de medicação</span>
        </div>
        <div class="login-hero__feature">
          <div class="login-hero__feature-icon"><i class='bx bx-check'></i></div>
          <span>Histórico completo do paciente</span>
        </div>
      </div>
    </div>
  </div>

  <div class="login-form-section">
    <div class="login-form-card stagger-item" style="--i:4">
      <div class="login-form__header">
        <h2>Acessar Plataforma</h2>
        <p>Entre com suas credenciais</p>
      </div>

      <form id="login-form" novalidate>
        <div class="floating-input">
          <input id="email" type="email" placeholder=" " required autocomplete="email">
          <label for="email">E-mail</label>
        </div>
        <div class="floating-input">
          <input id="password" type="password" placeholder=" " required autocomplete="current-password">
          <label for="password">Senha</label>
          <button type="button" class="password-toggle" data-toggle-password="password" aria-label="Mostrar senha">
            <i class='bx bx-hide'></i>
            <i class='bx bx-show'></i>
          </button>
        </div>
        <div id="login-error" class="form-error hidden"></div>
        <button type="submit" class="login-btn">
          Entrar
          <span class="login-btn__arrow"><i class='bx bx-right-arrow-alt'></i></span>
        </button>
      </form>

      <div class="login-form__footer">
        Não tem conta? <a href="/register" id="link-register">Criar Conta</a>
      </div>

      <div class="login-form__demo">
        <p>Acesso Demo</p>
        <div class="demo-credentials">
          <div class="demo-credentials__item">
            <span class="demo-badge demo-badge--doctor">Médico</span>
            <code>carlos@medcontrol.com</code>
            <span style="color:rgba(255,255,255,0.2)">/</span>
            <code>med123</code>
          </div>
          <div class="demo-credentials__item">
            <span class="demo-badge demo-badge--patient">Paciente</span>
            <code>paciente@email.com</code>
            <span style="color:rgba(255,255,255,0.2)">/</span>
            <code>123456</code>
          </div>
          <div class="demo-credentials__item">
            <span class="demo-badge demo-badge--patient">Paciente (push)</span>
            <code>maria@email.com</code>
            <span style="color:rgba(255,255,255,0.2)">/</span>
            <code>123456</code>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="module">
  import { renderLogin } from '/js/modules/auth.js';
  renderLogin();
</script>
<%- include('../layouts/foot') %>
