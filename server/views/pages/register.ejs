<%- include('../layouts/head', { title: 'Registro' }) %>

<div class="login-page">
  <div class="login-bg">
    <div class="login-bg__mesh"></div>
    <div class="login-bg__grid"></div>
    <div class="login-bg__orb login-bg__orb--1"></div>
    <div class="login-bg__orb login-bg__orb--2"></div>
    <div class="login-bg__orb login-bg__orb--3"></div>
  </div>

  <div class="login-hero">
    <div class="login-hero__content">
      <div class="login-hero__brand stagger-item" style="--i:0">
        <div class="login-hero__brand-icon"><i class='bx bx-plus-medical'></i></div>
        <h1>Med<span>Control</span></h1>
        <p class="login-hero__tagline">Gestão de Medicamentos</p>
      </div>

      <p class="login-hero__description stagger-item" style="--i:1">
        Crie sua conta e comece a gerenciar prescrições de forma inteligente.
      </p>

      <div class="login-hero__features stagger-item" style="--i:2">
        <div class="login-hero__feature">
          <div class="login-hero__feature-icon"><i class='bx bx-check'></i></div>
          <span>Prescrições digitais seguras</span>
        </div>
        <div class="login-hero__feature">
          <div class="login-hero__feature-icon"><i class='bx bx-check'></i></div>
          <span>Lembretes automáticos de medicação</span>
        </div>
        <div class="login-hero__feature">
          <div class="login-hero__feature-icon"><i class='bx bx-check'></i></div>
          <span>Histórico completo do paciente</span>
        </div>
      </div>
    </div>
  </div>

  <div class="login-form-section">
    <div class="login-form-card stagger-item" style="--i:3" style="max-width:440px">
      <div class="login-form__header">
        <h2>Criar Conta</h2>
        <p>Cadastre-se como médico</p>
      </div>

      <form id="register-form" novalidate>
        <div class="floating-input">
          <input id="reg-name" type="text" placeholder=" " required autocomplete="name">
          <label for="reg-name">Nome Completo</label>
        </div>
        <div class="floating-input">
          <input id="reg-email" type="email" placeholder=" " required autocomplete="email">
          <label for="reg-email">E-mail</label>
        </div>
        <div class="floating-input">
          <input id="reg-password" type="password" placeholder=" " required autocomplete="new-password" minlength="6">
          <label for="reg-password">Senha</label>
          <button type="button" class="password-toggle" data-toggle-password="reg-password" aria-label="Mostrar senha">
            <i class='bx bx-hide'></i>
            <i class='bx bx-show'></i>
          </button>
        </div>
        <div class="floating-input">
          <input id="reg-password-confirm" type="password" placeholder=" " required autocomplete="new-password">
          <label for="reg-password-confirm">Confirmar Senha</label>
          <button type="button" class="password-toggle" data-toggle-password="reg-password-confirm" aria-label="Mostrar senha">
            <i class='bx bx-hide'></i>
            <i class='bx bx-show'></i>
          </button>
        </div>
        <div id="register-error" class="form-error hidden"></div>
        <button type="submit" class="login-btn">
          Criar Conta
          <span class="login-btn__arrow"><i class='bx bx-right-arrow-alt'></i></span>
        </button>
      </form>

      <div class="login-form__footer">
        Já tem conta? <a href="/" id="link-login">Fazer Login</a>
      </div>
    </div>
  </div>
</div>

<script type="module">
  import { renderRegister } from '/js/modules/auth.js';
  renderRegister();
</script>
<%- include('../layouts/foot') %>
